# Required for local app startup
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transcrivo_web
BETTER_AUTH_URL=http://localhost:3000
AUTH_EMAIL_FROM=Transcrivo <auth@example.com>
TOKEN_SECRET=change-me-to-a-random-secret

# Required only for OpenRouter-powered AI features
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=transcrivo

# Optional for real email delivery in auth flows
RESEND_API_KEY=

# Optional transcript debugging
# Set to 1 to write transcript events to web/logs/transcription.ndjson
TRANSCRIPTION_DEBUG_FILE=0

# Optional websocket ingest debug logging
# Set to 1 to enable verbose ws-ingest connection/message logs
WEBSOCKET_DEBUG_LOGS=0
